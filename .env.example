SPECTRUMCLAW_ENV=local
SPECTRUMCLAW_AGENT_RUNTIME=langgraph
SPECTRUMCLAW_LLM_PROVIDER=deepseek
SPECTRUMCLAW_LLM_BASE_URL=
SPECTRUMCLAW_LLM_API_KEY=
SPECTRUMCLAW_LLM_MODEL=
SPECTRUMCLAW_PROJECT_ROOT=/home/lenovo/workspace/SpectrumClaw
SPECTRUMCLAW_KB_ZIP=/home/lenovo/workspace/SpectrumClaw/itu_documents.zip

# Optional provider-specific aliases.
# OpenAI-compatible: openai / deepseek / qwen / custom proxies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
DASHSCOPE_API_KEY=

# Anthropic-compatible: Anthropic official or third-party Claude-compatible API.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=

# Web search (Tavily — free tier 1000 searches/month: https://tavily.com)
TAVILY_API_KEY=

# ── RAG Multimodal Pipeline ──

# Qwen-VL image understanding (DashScope API: https://dashscope.console.aliyun.com)
QWEN_VL_API_KEY=
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max

# MinerU parser (Docker endpoint — leave empty to use local magic-pdf)
MINERU_ENDPOINT=

# Qwen Embedding (optional — falls back to local sentence-transformers if empty)
QWEN_EMBEDDING_API_KEY=

# Parser override: mineru | pypdf
SPECTRUMCLAW_PARSER=pypdf

# ── Memory & Evolution ──
SPECTRUMCLAW_MEMORY_ENABLED=true
SPECTRUMCLAW_MEMORY_DB_PATH=data/memory/spectrum_memory.sqlite3
SPECTRUMCLAW_MEMORY_INJECT_TOP_K=5
SPECTRUMCLAW_MEMORY_SUMMARIZE_EVERY=6
